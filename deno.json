{
  "name": "@bounded-systems/gh-project-room",
  "version": "0.2.2",
  "license": "PolyForm-Noncommercial-1.0.0",
  "exports": {
    ".": "./contract.ts",
    "./prioritization": "./prioritization.ts",
    "./board-inputs": "./board-inputs.ts",
    "./reads": "./reads.ts",
    "./sync": "./sync.ts",
    "./ready": "./ready.ts",
    "./verbs": "./verbs.ts",
    "./webhook": "./webhook.ts",
    "./health": "./health.ts"
  },
  "imports": {
    "zod": "npm:zod@^4.4.3",
    "verbspec": "jsr:@bounded-systems/verbspec@^0.3.1",
    "@bounded-systems/verbspec-mcp": "jsr:@bounded-systems/verbspec-mcp@^0.1.0",
    "@std/assert": "jsr:@std/assert@^1"
  },
  "tasks": {
    "check": "deno check contract.ts prioritization.ts board-inputs.ts projects.ts reads.ts schema.ts sync.ts ready.ts verbs.ts mcp.ts webhook.ts health.ts budget-check.ts traceability-check.ts health-issue.ts",
    "webhook": "deno run --allow-net --allow-env webhook.ts",
    "ready": "deno run --allow-net=api.github.com --allow-env verbs.ts ready",
    "mcp": "deno run --allow-net=api.github.com --allow-env mcp.ts",
    "health": "deno run --allow-net=api.github.com --allow-env health.ts",
    "health-issue": "deno run --allow-net=api.github.com --allow-env health-issue.ts",
    "test": "deno test",
    "fmt": "deno fmt",
    "lint": "deno lint"
  },
  "fmt": {
    "include": [
      "*.ts"
    ]
  },
  "lint": {
    "include": [
      "*.ts"
    ]
  },
  "publish": {
    "include": [
      "contract.ts",
      "prioritization.ts",
      "board-inputs.ts",
      "reads.ts",
      "scout-reads.ts",
      "projects.ts",
      "sync.ts",
      "ready.ts",
      "schema.ts",
      "verbs.ts",
      "webhook.ts",
      "health.ts",
      "LICENSE",
      "README.md"
    ]
  }
}
